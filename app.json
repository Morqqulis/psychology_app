{
	"expo": {
		"name": "nur_yolu",
		"owner": "StarCode.Dev",
		"slug": "nur-yolu",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./assets/images/logo.png",
		"scheme": "nuryolu",
		"userInterfaceStyle": "automatic",
		"ios": {
			"icon": "./assets/images/logo.png",
			"supportsTablet": true,
			"bundleIdentifier": "com.nuryolu.app",
			"associatedDomains": ["applinks:psychology-eosin.vercel.app", "webcredentials:psychology-eosin.vercel.app"]
		},
		"android": {
			"icon": "./assets/images/logo.png",
			"package": "com.nuryolu.app",
			"adaptiveIcon": {
				"backgroundColor": "#E6F4FE",
				"foregroundImage": "./assets/images/logo.png",
				"backgroundImage": "./assets/images/android-icon-background.png",
				"monochromeImage": "./assets/images/android-icon-monochrome.png"
			},
			"predictiveBackGestureEnabled": false,
			"intentFilters": [
				{
					"action": "VIEW",
					"autoVerify": true,
					"data": [
						{
							"scheme": "https",
							"host": "psychology-eosin.vercel.app",
							"pathPrefix": "/ref"
						},
						{
							"scheme": "https",
							"host": "psychology-eosin.vercel.app",
							"pathPrefix": "/pay"
						}
					],
					"category": ["BROWSABLE", "DEFAULT"]
				}
			]
		},
		"web": {
			"bundler": "metro",
			"output": "static",
			"favicon": "./assets/images/logo.png"
		},
		"plugins": [
			[
				"expo-audio",
				{
					"microphonePermission": "Allow Nur Yolu to access your microphone."
				}
			],
			"expo-router",
			[
				"expo-splash-screen",
				{
					"image": "./assets/images/splash-icon.png",
					"imageWidth": 200,
					"resizeMode": "contain",
					"backgroundColor": "#ffffff",
					"dark": {
						"backgroundColor": "#000000"
					}
				}
			]
		],
		"experiments": {
			"typedRoutes": true,
			"reactCompiler": true
		},
		"extra": {
			"router": {},
			"eas": {
				"projectId": "b3c28066-96e5-474a-86ae-3007da84624c"
			}
		}
	}
}
