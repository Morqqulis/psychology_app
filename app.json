{
	"expo": {
		"name": "Nur Yolu",
		"owner": "starcode.dev",
		"slug": "psychology",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./assets/images/icon-ios.png",
		"scheme": "nuryolu",
		"userInterfaceStyle": "automatic",
		"ios": {
			"icon": "./assets/images/icon-ios.png",
			"supportsTablet": true,
			"bundleIdentifier": "com.nuryolu.app",
			"associatedDomains": ["applinks:psychology-eosin.vercel.app", "webcredentials:psychology-eosin.vercel.app"],
			"infoPlist": {
				"ITSAppUsesNonExemptEncryption": false,
				"NSSpeechRecognitionUsageDescription": "Allow Nur Yolu to securely process your voice input for recognition.",
				"NSPhotoLibraryUsageDescription": "Allow Nur Yolu to access your photo library so you can pick profile images."
			}
		},
		"android": {
			"icon": "./assets/images/icon-android-foreground.png",
			"package": "com.nuryolu.app",
			"adaptiveIcon": {
				"backgroundColor": "#E6F4FE",
				"foregroundImage": "./assets/images/icon-android-foreground.png"
			},
			"predictiveBackGestureEnabled": false,
			"intentFilters": [
				{
					"action": "VIEW",
					"autoVerify": true,
					"data": [
						{
							"scheme": "https",
							"host": "psychology-eosin.vercel.app",
							"pathPrefix": "/ref"
						},
						{
							"scheme": "https",
							"host": "psychology-eosin.vercel.app",
							"pathPrefix": "/pay"
						}
					],
					"category": ["BROWSABLE", "DEFAULT"]
				}
			],
			"permissions": ["android.permission.RECORD_AUDIO", "android.permission.MODIFY_AUDIO_SETTINGS"]
		},
		"web": {
			"bundler": "metro",
			"output": "static",
			"favicon": "./assets/images/logo.png"
		},
		"plugins": [
			[
				"expo-audio",
				{
					"microphonePermission": "Allow Nur Yolu to access your microphone."
				}
			],
			"expo-router",
			[
				"expo-splash-screen",
				{
					"image": "./assets/images/splash-icon.png",
					"imageWidth": 250,
					"resizeMode": "contain",
					"backgroundColor": "#ffffff",
					"dark": {
						"backgroundColor": "#000000"
					}
				}
			],
			"expo-asset"
		],
		"experiments": {
			"typedRoutes": true,
			"reactCompiler": true
		},
		"extra": {
			"router": {},
			"eas": {
				"projectId": "b3c28066-96e5-474a-86ae-3007da84624c"
			}
		},
		"runtimeVersion": {
			"policy": "appVersion"
		},
		"updates": {
			"url": "https://u.expo.dev/b3c28066-96e5-474a-86ae-3007da84624c"
		}
	}
}
